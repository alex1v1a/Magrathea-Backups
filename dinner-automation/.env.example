# Dinner Automation Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# REQUIRED: iCloud app-specific password for email/calendar (from Apple ID settings)
# To generate: Apple ID Settings > Sign-In & Security > App-Specific Passwords
ICLOUD_APP_PASSWORD=

# iCloud email address (default: MarvinMartian9@icloud.com)
# ICLOUD_EMAIL=MarvinMartian9@icloud.com

# iCloud account password (for general account access) - not typically needed
# ICLOUD_PASSWORD=

# --- Optional Credentials ---

# Gmail address (optional, for secondary email)
# GMAIL_EMAIL=

# Gmail app password (optional)
# GMAIL_PASSWORD=

# HEB.com login email
# Default: alex@1v1a.com
# HEB_EMAIL=alex@1v1a.com

# HEB.com login password
# HEB_PASSWORD=

# Home Assistant Long-Lived Access Token
# HOMEASSISTANT_TOKEN=

# Home Assistant URL
# Default: http://localhost:8123
# HOMEASSISTANT_URL=http://localhost:8123

# Wyze account email
# WYZE_EMAIL=

# Wyze account password
# WYZE_PASSWORD=

# Wyze API Key
# WYZE_API_KEY=

# Wyze API Key ID
# WYZE_API_KEY_ID=

# Govee API Key
# GOVEE_API_KEY=

# Discord webhook URL for dinner notifications
# DINNER_DISCORD_WEBHOOK=

# OpenClaw webhook token for HA integration
# OPENCLAW_WEBHOOK_TOKEN=

# Minimax account email
# MINIMAX_EMAIL=

# Minimax account password
# MINIMAX_PASSWORD=
