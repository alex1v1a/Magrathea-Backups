# Environment Variables for OpenClaw Workspace
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# API Keys - Required for fetch-api-data.js
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
KIMI_API_KEY=your_kimi_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional API Keys
BRAVE_API_KEY=your_brave_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Service Credentials
HEB_USERNAME=your_heb_email
HEB_PASSWORD=your_heb_password

FACEBOOK_USERNAME=your_facebook_email
FACEBOOK_PASSWORD=your_facebook_password

# iCloud (Marvin's email)
ICLOUD_EMAIL=marvinmartian9@icloud.com
ICLOUD_APP_PASSWORD=your_icloud_app_password

# OpenClaw
OPENCLAW_WEBHOOK_TOKEN=your_openclaw_webhook_token

# Discord Webhooks
KANBAN_DISCORD_WEBHOOK=your_discord_webhook_url

# Home Assistant
HA_URL=http://10.0.1.90:8123
HA_TOKEN=your_long_lived_access_token

# WiFi (for ESPHome devices)
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password

# API Encryption (for ESPHome)
API_ENCRYPTION_KEY=your_api_encryption_key

# OTA Password (for ESPHome)
OTA_PASSWORD=your_ota_password
